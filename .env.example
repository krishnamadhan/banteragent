# Path to Chromium/Chrome — set this on Raspberry Pi (ARM64)
# Run: which chromium-browser   to find the path
# On Pi OS Bookworm it may be /usr/bin/chromium instead
CHROME_PATH=/usr/bin/chromium-browser

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Cricket API (cricapi.com free tier)
CRICKET_API_KEY=your_cricket_api_key_here

# Bot Config
BOT_GROUP_ID=120363xxxx@g.us
# ^ Find this after first run — bot logs all group IDs on startup

# Auto-response settings
AUTO_RESPONSE_COOLDOWN_MINS=45
AUTO_RESPONSE_DAILY_MAX=8
NIGHT_MODE_START=23
NIGHT_MODE_END=7

# ── IPL Fantasy Integration ─────────────────────────────────────────────────
# URL of the deployed fantasy app (no trailing slash)
FANTASY_APP_URL=https://your-ipl-fantasy-app.vercel.app
# Shared secret — must match BOT_SECRET in the fantasy app's .env.local
FANTASY_BOT_SECRET=a-long-random-secret-string
# Comma-separated WhatsApp phone numbers of admins (can run !fantasy lock etc.)
# Format: 919876543210 (country code + number, no +, no spaces)
FANTASY_ADMIN_PHONES=919487506127,917204917771
